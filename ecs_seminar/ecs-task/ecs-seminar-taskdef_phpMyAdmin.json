{
  "family": "ecs-seminar-task-phpmyadmin-<氏名>",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::12345678910:role/ecsTaskExecutionRole-<氏名>",
  "containerDefinitions": [
    {
      "name": "phpmyadmin",
      "image": "12345678910.dkr.ecr.ap-northeast-1.amazonaws.com/phpmyadmin-<氏名>:5.2.1",
      "memory": 512,
      "cpu": 256,
      "essential": true,
      "portMappings": [
        {"containerPort": 80}
      ],
      "environment": [
        { "name": "PMA_HOST", "value": "<rdsのエンドポイント>" },
        { "name": "PMA_USER", "value": "root" },
        { "name": "PMA_PASSWORD", "value": "root1234" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ecs-seminar-task-<氏名>",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "phpmyadmin"
        }
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
